<div class="paginakop">
  <div class="wrap">
    <div>
      <span class="kicker">Beheer</span>
      <h1><%= title %></h1>
    </div>
    <a href="/agenda" class="btn btn--ghost">← Agenda</a>
  </div>
</div>

<section class="section section--tight">
  <div class="wrap" style="max-width:720px;">
    <% if (fout) { %><div class="flash flash--fout"><%= fout %></div><% } %>

    <form action="<%= actie %>" method="post" enctype="multipart/form-data" class="form-card stack">
      <div class="veld">
        <label for="titel">Titel *</label>
        <input type="text" id="titel" name="titel" value="<%= evenement.titel || '' %>" required autofocus>
      </div>

      <div class="veld-rij">
        <div class="veld">
          <label for="categorie">Categorie</label>
          <select id="categorie" name="categorie">
            <option value="">—</option>
            <% categorieen.forEach(function(c){ %>
              <option value="<%= c %>" <%= evenement.categorie === c ? 'selected' : '' %>><%= c %></option>
            <% }) %>
          </select>
        </div>
        <div class="veld">
          <label for="locatie">Locatie</label>
          <input type="text" id="locatie" name="locatie" value="<%= evenement.locatie || '' %>" placeholder="Bijv. Oranjekazerne, Schaarsbergen">
        </div>
      </div>

      <div class="veld-rij">
        <div class="veld">
          <label for="start_op">Start (datum &amp; tijd) *</label>
          <input type="datetime-local" id="start_op" name="start_op" value="<%= h.toDatetimeLocal(evenement.start_op) %>" required>
        </div>
        <div class="veld">
          <label for="eind_op">Einde (optioneel)</label>
          <input type="datetime-local" id="eind_op" name="eind_op" value="<%= h.toDatetimeLocal(evenement.eind_op) %>">
        </div>
      </div>

      <div class="veld">
        <label for="omschrijving">Omschrijving</label>
        <textarea id="omschrijving" name="omschrijving" rows="6" placeholder="Wat kunnen leden verwachten?"><%= evenement.omschrijving || '' %></textarea>
      </div>

      <div class="veld-rij">
        <div class="veld">
          <label for="max_plaatsen">Max. aantal plaatsen (optioneel)</label>
          <input type="number" id="max_plaatsen" name="max_plaatsen" min="1" value="<%= evenement.max_plaatsen || '' %>">
        </div>
        <div class="veld" style="display:flex; align-items:center;">
          <label style="display:flex; align-items:center; gap:10px; cursor:pointer; margin-top:22px;">
            <input type="checkbox" name="aanmelden" style="width:auto;" <%= (evenement.aanmelden === undefined || evenement.aanmelden) ? 'checked' : '' %>>
            Aanmelden mogelijk maken
          </label>
        </div>
      </div>

      <div class="veld">
        <label for="afbeelding">Afbeelding (optioneel)</label>
        <input type="file" id="afbeelding" name="afbeelding" accept="image/*">
      </div>

      <button type="submit" class="btn btn--primary">Opslaan</button>
    </form>
  </div>
</section>
