<div class="paginakop">
  <div class="wrap">
    <div>
      <span class="kicker">Vacature</span>
      <h1><%= title %></h1>
    </div>
    <a href="/vacatures" class="btn btn--ghost">← Annuleren</a>
  </div>
</div>

<section class="section">
  <div class="wrap" style="max-width:760px;">
    <% if (fout) { %><div class="flash flash--fout"><%= fout %></div><% } %>
    <form action="<%= actie %>" method="post" class="form-card">
      <div class="veld">
        <label for="titel">Functietitel *</label>
        <input type="text" id="titel" name="titel" value="<%= vacature.titel || '' %>" required>
      </div>
      <div class="veld-rij">
        <div class="veld"><label for="bedrijf">Bedrijf</label><input type="text" id="bedrijf" name="bedrijf" value="<%= vacature.bedrijf || '' %>"></div>
        <div class="veld"><label for="plaats">Plaats</label><input type="text" id="plaats" name="plaats" value="<%= vacature.plaats || '' %>"></div>
      </div>
      <div class="veld">
        <label for="dienstverband">Dienstverband</label>
        <select id="dienstverband" name="dienstverband">
          <option value="">Kies…</option>
          <% dienstverbanden.forEach(function(d){ %>
            <option value="<%= d %>" <%= vacature.dienstverband === d ? 'selected' : '' %>><%= d %></option>
          <% }) %>
        </select>
      </div>
      <div class="veld">
        <label for="omschrijving">Omschrijving</label>
        <textarea id="omschrijving" name="omschrijving" placeholder="Wat houdt de functie in? Wat zoek je?"><%= vacature.omschrijving || '' %></textarea>
      </div>
      <div class="veld-rij">
        <div class="veld"><label for="contact_email">Contact-e-mail</label><input type="email" id="contact_email" name="contact_email" value="<%= vacature.contact_email || '' %>"></div>
        <div class="veld"><label for="link">Link (optioneel)</label><input type="text" id="link" name="link" value="<%= vacature.link || '' %>" placeholder="www.bedrijf.nl/vacature"></div>
      </div>
      <div class="veld">
        <label class="check"><input type="checkbox" name="veteraan_vriendelijk" <%= vacature.veteraan_vriendelijk ? 'checked' : '' %>> Deze functie is bij uitstek geschikt voor veteranen</label>
      </div>
      <button type="submit" class="btn btn--primary">Opslaan</button>
    </form>
  </div>
</section>
