<div class="auth-wrap">
  <div class="auth-card">
    <span class="kicker">Welkom terug</span>
    <h1>Inloggen</h1>
    <p class="muted">Log in op het ledenplatform.</p>

    <% if (fout) { %><div class="flash flash--fout"><%= fout %></div><% } %>

    <form action="/inloggen" method="post" class="stack">
      <div class="veld">
        <label for="email">E-mailadres</label>
        <input type="email" id="email" name="email" value="<%= waarden.email || '' %>" required autofocus>
      </div>
      <div class="veld">
        <label for="wachtwoord">Wachtwoord</label>
        <input type="password" id="wachtwoord" name="wachtwoord" required>
      </div>
      <button type="submit" class="btn btn--primary btn--block">Inloggen</button>
    </form>

    <div class="auth-onder">Nog geen account? <a href="/registreren">Word lid</a></div>
  </div>
</div>
