# Kopieer dit bestand naar .env voor lokaal gebruik.
# Op Railway zet je deze waarden onder "Variables".

# Door Railway automatisch ingevuld als je de PostgreSQL-plugin toevoegt:
DATABASE_URL=postgresql://gebruiker:wachtwoord@localhost:5432/luchtmobiel

# Geheime sleutel voor sessies. Maak hier een lange willekeurige tekst van.
SESSION_SECRET=verander-mij-in-een-lange-willekeurige-tekst

# Het eerste adminaccount (Daniël). Wordt automatisch aangemaakt bij de eerste start.
ADMIN_EMAIL=jij@voorbeeld.nl
ADMIN_PASSWORD=kies-een-sterk-wachtwoord
ADMIN_NAAM=Daniël de Graaf

# Toegangscode voor registratie. Leeg laten = iedereen mag registreren.
# Vul je iets in, dan hebben nieuwe leden deze code nodig om een account te maken.
REGISTRATIE_CODE=LUCHTMOBIEL

# Zet op 'production' op Railway (zorgt voor veilige cookies via https).
NODE_ENV=production
